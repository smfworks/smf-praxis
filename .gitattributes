# Shell scripts must keep LF endings so they run on Linux/macOS even when the
# repo is cloned or edited on Windows.
*.sh text eol=lf

# Keep these text files normalized to LF as well.
*.py text eol=lf
*.toml text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.cfg text eol=lf

# PowerShell stays CRLF (Windows-native).
*.ps1 text eol=crlf
